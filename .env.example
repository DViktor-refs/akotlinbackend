# ---- Szerver ----
# Railway-en a PORT-ot a platform automatikusan adja, lokalisan allithatod.
PORT=3000

# A backend publikus URL-je. Railway-en allitsd be a deploy utan kapott domaint,
# pl. https://webshop-backend-production.up.railway.app
# Ebbol epul a Barion callback URL.
BASE_URL=

# ---- Adatbazis ----
# Railway: add hozza a PostgreSQL plugint, ezt automatikusan beallitja.
# Lokalisan: postgres://user:pass@localhost:5432/webshop
DATABASE_URL=
# Kulso/publikus connection stringnel: true. Railway belso halozatan: false (alapertelmezett).
PGSSL=false

# ---- Auth ----
# Generalj egy hosszu veletlen stringet, pl: openssl rand -hex 32
JWT_SECRET=valtoztasd-meg-egy-hosszu-veletlen-ertekre

# Default userek (opcionalis feluliras). Alapbol: admin/admin es v/v123
# ADMIN_USER=admin
# ADMIN_PASS=admin
# USER_USER=v
# USER_PASS=v123

# ---- Barion ----
# A boltod POSKey-e (Barion fiok -> Bolt -> POSKey)
BARION_POSKEY=
# A boltod email cime (Payee), amire a penz erkezik
BARION_PAYEE=teboltod@email.hu
# test = sandbox (api.test.barion.com), prod = eles (api.barion.com)
BARION_ENV=test
# A fizeto feluletenek nyelve
BARION_LOCALE=hu-HU

# ---- Bolt ----
# Penznem: HUF, EUR, USD, CZK. HUF-nal egesz osszegek kellenek.
# (A dummyjson arak ~USD ertekuek, ezert teszthez USD is jo valasztas.)
CURRENCY=HUF

# Ha van kulon frontended, ide ter vissza a vasarlo fizetes utan.
# Ha ures, a beepitett /payment-result oldal jelenik meg.
FRONTEND_URL=

# A termekek forrasa (alapbol az osszes dummyjson termek)
# PRODUCTS_SOURCE_URL=https://dummyjson.com/products?limit=0
